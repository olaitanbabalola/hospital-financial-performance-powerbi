				    #"Changed Type1" = Table.TransformColumnTypes(#"Changed Type",{{"ChargeAmount", Currency.Type}, {"PaymentAmount", Currency.Type}, {"ContractualAdjustment", Currency.Type}, {"NetRevenue", Currency.Type}})
