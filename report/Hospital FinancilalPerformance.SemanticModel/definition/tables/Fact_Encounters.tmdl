table Fact_Encounters
	lineageTag: 4636f1c6-2a8b-48ae-9b2a-f3049af6ef4a

	measure '_Net revenue' = SUM('Fact_Encounters'[NetRevenue])
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: DAX Measures 1
		lineageTag: bf1a2119-e41d-476f-ab12-ad1c91d326c9

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure '_Net revenue(per year)' =
			CALCULATE(
			        [_Net revenue], SAMEPERIODLASTYEAR( 'Dim_Date'[Date]))
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: DAX Measures 1
		lineageTag: 992cfe9f-ecf9-463e-b92f-ed251e905450

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure '_YOY Growth %' = ```
			
			 VAR Currentrevenue = [_Net revenue]
			 Var Prioryearrevenue = [_Net revenue(per year)]
			  RETURN
			  DIVIDE(Currentrevenue- Prioryearrevenue, Prioryearrevenue, 0)
			```
		displayFolder: DAX Measures 1
		lineageTag: dc406178-7145-4689-a842-988f979f1ead

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '_Total Operating Cost' = SUM (Fact_OperatingCosts[Amount])
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: DAX Measures 1
		lineageTag: 0d40b926-0fcd-4824-b341-497b3efee3e8

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure '_OPERATING MARGIN' = [_Net revenue] - [_Total Operating Cost]
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: DAX Measures 1
		lineageTag: e09efffb-25b1-4860-88fc-89ac73f9d101

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure '_% Operating Margin' = DIVIDE( [_OPERATING MARGIN], [_Net revenue])
		displayFolder: DAX Measures 1
		lineageTag: 73e2363f-f9e1-488d-bb5a-e907367afdec

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '_Total encounters' = COUNTROWS(Fact_Encounters)
		formatString: 0
		displayFolder: DAX Measures 1
		lineageTag: f53d7e1f-e191-4c1b-a811-ebaed4d8052f

	measure '_Total Charges' = SUM(Fact_Encounters[ChargeAmount])
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: DAX Measures 1
		lineageTag: 5ecc9f80-3546-461c-88ae-1769524da434

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure '_Revenue per encounter' = DIVIDE([_Net revenue], [_Total encounters], 0)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: DAX Measures 1
		lineageTag: bb69abff-8335-47c1-b7c6-c8f1ba15c7bc

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure '_Total Contractuals' = SUM(Fact_Encounters[ContractualAdjustment])
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: DAX Measures 1
		lineageTag: fbe36755-3e6e-4796-bfcb-690e003db60f

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure '_Bridge value' = ```
			
			            SWITCH(
			                SELECTEDVALUE('_Revenue Bridge'[Step]), 
			                "Gross Charges", [_Total Charges],
			                "Contractual Adj", - [_Total Contractuals], BLANK()
			                )
			                
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: DAX Measures 1
		lineageTag: f4f98045-bdf2-44c8-891e-f2b34faccd36

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure '_Net Yield %' = DIVIDE([_Net revenue], [_Total Charges])
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: DAX Measures 1
		lineageTag: f414bcce-d6c7-4615-b647-27a3688de35c

	measure '_Total Budget Revenue' = SUM('Fact_Budget'[BudgetRevenue])
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: DAX Measures 1
		lineageTag: 7c82b4b3-9f48-4e7c-9ae0-6c023fd9db21

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure '_Revenue Variance' = [_Net revenue] - [_Total Budget Revenue]
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: DAX Measures 1
		lineageTag: 114ad6ce-68db-4e93-a9d9-c0bb47221395

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure '_Revenue Variance %' = DIVIDE([_Revenue Variance], [_Total Budget Revenue])
		displayFolder: DAX Measures 1
		lineageTag: 3b9ee29e-7b84-4235-b6f4-1a192edd5880

		annotation PBI_FormatHint = {"isGeneralNumber":true}

